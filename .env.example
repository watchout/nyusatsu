# === データベース ===
DATABASE_URL=postgresql+asyncpg://nyusatsu:nyusatsu_dev@localhost:5433/nyusatsu
# VPS/本番環境でのSSL設定:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db?ssl=require
# asyncpgはsslmode=requireではなくssl=requireを使用
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# === LLM API ===
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# === アプリケーション ===
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_LOG_DIR=logs/

# === バッチ ===
BATCH_SCHEDULE_CASE_FETCH=0 6 * * *
BATCH_SCHEDULE_OD_IMPORT=0 6 * * *
BATCH_SCHEDULE_DETAIL_SCRAPE=0 7 * * *

# === データ保存 ===
DATA_RAW_DIR=data/raw/

# === コスト制御 ===
LLM_DAILY_TOKEN_LIMIT=0

# === Telegram通知 ===
# BotFatherから取得したボットトークン
# 形式: <BotToken>
TELEGRAM_BOT_TOKEN=
# 通知先チャットID（個人またはグループ）
# グループIDの場合は負の数値になることがあります
TELEGRAM_CHAT_ID=
