{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-code-gate.sh\"",
            "statusMessage": "Pre-Code Gate check..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-tracker.sh\"",
            "statusMessage": "Tracking skill activation..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat /Users/yuji/Developer/nyusatsu/nyusatsu-dev-state.md 2>/dev/null || echo 'No state file found. Run fetch_messages to restore context.'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[PreCompact] Update nyusatsu-dev-state.md before compaction completes.'"
          }
        ]
      }
    ]
  }
}
